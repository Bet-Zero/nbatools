# Environment variables for nbatools
# Copy this file to .env and fill in values as needed.

# No secrets are currently required for basic usage.
# The nba_api library does not require an API key.

# If you add Discord integration or other services:
# DISCORD_TOKEN=your_token_here

# Cloudflare R2 data sync / deployed data source.
# Fill these in locally in .env; configure the same names in Vercel.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nbatools-data

# Deferred optional query feedback storage. The current public release leaves
# QUERY_FEEDBACK_STORE empty and does not expose a feedback submission control.
# A future approved activation must use its own R2 credential tuple.
QUERY_FEEDBACK_STORE=
QUERY_FEEDBACK_BUCKET_NAME=nbatools-feedback
QUERY_FEEDBACK_PREFIX=query_feedback
QUERY_FEEDBACK_R2_ACCOUNT_ID=
QUERY_FEEDBACK_R2_ACCESS_KEY_ID=
QUERY_FEEDBACK_R2_SECRET_ACCESS_KEY=
