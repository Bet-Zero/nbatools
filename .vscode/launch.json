{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "nbatools-cli ask",
      "type": "debugpy",
      "request": "launch",
      "module": "nbatools.cli",
      "args": ["ask", "Jokic recent form"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "nbatools-cli query",
      "type": "debugpy",
      "request": "launch",
      "module": "nbatools.cli",
      "args": ["query", "--help"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
